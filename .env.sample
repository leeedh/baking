# =============================================================================
# Crème Pâtisserie Academy — 환경변수 샘플
# -----------------------------------------------------------------------------
# 사용법: 이 파일을 `.env.local`로 복사한 뒤 실제 값을 채워 넣으세요.
#   cp .env.sample .env.local
#
# - NEXT_PUBLIC_* 접두사가 붙은 값은 브라우저(클라이언트)에 노출됩니다.
#   → 공개돼도 안전한 값(URL, publishable/anon 키)만 넣으세요.
# - 접두사가 없는 값은 서버 전용입니다. 절대 클라이언트 코드에서 참조하지 마세요.
# - .env.local 은 절대 커밋하지 마세요 (.gitignore로 차단됨).
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — 프로젝트 연결 (필수)
# -----------------------------------------------------------------------------
# Supabase 대시보드 > Project Settings > Data API 에서 확인
# https://supabase.com/dashboard/project/_/settings/api

# 프로젝트 API URL (예: https://xxxxxxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# 공개(anon/publishable) 키 — 브라우저에서 사용, RLS로 보호됨
# 신규 프로젝트는 sb_publishable_... 형식, 기존 프로젝트는 JWT(anon) 형식
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# Supabase — 서버 전용 시크릿 (결제 확정에 필수)
# -----------------------------------------------------------------------------
# service_role(또는 sb_secret_...) 키. RLS를 우회하는 전권 키이므로
# 서버 사이드에서만 사용하고, 절대 NEXT_PUBLIC_ 로 노출하지 마세요.
# 결제 Route Handler(주문 생성·grant_enrollment 호출)가 사용합니다.
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# TossPayments v2 (결제, EPIC-D)
# -----------------------------------------------------------------------------
# 개발자센터(https://developers.tosspayments.com) > 내 개발정보에서 확인.
# 아래 test_gck/gsk_docs_... 는 공식 문서의 공개 샌드박스 키(실결제 없음).
# 실 가맹 시 live_... 키로 교체.
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_gck_docs_Ovk5rk1EwkEbP0W43n07xlzm
TOSS_SECRET_KEY=test_gsk_docs_OaPz8L5KdmQXkzRz3y47BMw6

# -----------------------------------------------------------------------------
# Supabase MCP — 로컬 개발 도구용 (선택)
# -----------------------------------------------------------------------------
# 호스팅형 MCP(https://mcp.supabase.com/mcp)는 OAuth로 인증하므로 보통 불필요.
# CLI/자체 호스팅 MCP를 쓸 때만 아래 값을 사용하세요.
# 액세스 토큰: https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=
# SUPABASE_PROJECT_REF=

# -----------------------------------------------------------------------------
# Jira MCP (mcp-atlassian) — 로컬 개발 도구용 (선택)
# -----------------------------------------------------------------------------
# .mcp.json의 mcp-atlassian 서버가 `--env-file .env.local`로 이 파일을 직접 읽습니다.
# 따라서 셸 환경변수로 export할 필요 없이, 아래 값만 채우면 됩니다.
# 값을 바꾼 뒤에는 Claude Code를 재시작해야 반영됩니다.
#
# API 토큰 발급: https://id.atlassian.com/manage-profile/security/api-tokens
# 연결 가이드/트러블슈팅: Docs/JiraMcpSetup.md
#
# JIRA_URL       사이트 루트 (끝에 / 없이)  예: https://your-site.atlassian.net
# JIRA_USERNAME  Atlassian 계정 이메일
# JIRA_API_TOKEN 위 링크에서 발급한 API 토큰 (발급 직후 1회만 표시됨)
JIRA_URL=
JIRA_USERNAME=
JIRA_API_TOKEN=
